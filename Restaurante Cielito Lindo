<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Cielito Lindo</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            margin: 0;
        }
        header {
            background: #8B0000;
            color: white;
            padding: 15px;
            text-align: center;
        }
        nav a {
            color: white;
            margin: 10px;
            text-decoration: none;
            font-weight: bold;
        }
        section {
            padding: 20px;
        }
        footer {
            background: #8B0000;
            color: white;
            text-align: center;
            padding: 10px;
        }
        form input, form button {
            display: block;
            margin: 10px 0;
            padding: 8px;
        }
    </style>
</head>
<body>

<header>
    <h1>Restaurante Cielito Lindo</h1>
    <nav>
        <a href="#inicio">Inicio</a>
        <a href="#menu">Menú</a>
        <a href="#reservas">Reservas</a>
        <a href="#acerca">Acerca de</a>
        <a href="#contacto">Contacto</a>
    </nav>
</header>

<section id="inicio">
    <h2>Bienvenidos</h2>
    <p>Disfruta de la auténtica comida mexicana en Cielito Lindo.</p>
</section>

<section id="menu">
    <h2>Menú</h2>
    <ul>
        <li>Tacos al pastor - $50</li>
        <li>Enchiladas - $90</li>
        <li>Quesadillas - $40</li>
    </ul>
</section>

<section id="reservas">
    <h2>Reservas</h2>
    <form>
        <input type="text" placeholder="Nombre" required>
        <input type="date" required>
        <button type="submit">Reservar</button>
    </form>
</section>

<section id="acerca">
    <h2>Acerca de</h2>
    <p>Somos un restaurante mexicano con tradición y sabor casero.</p>
</section>

<section id="contacto">
    <h2>Contacto</h2>
    <p>Email: contacto@cielitolindo.com</p>
    <p>Tel: 555-123-4567</p>
</section>

<footer>
    <p>© 2026 Restaurante Cielito Lindo</p>
    <p>
        <a href="#" style="color:white;">Términos y condiciones</a> | 
        <a href="#" style="color:white;">Política de privacidad</a>
    </p>
</footer>

</body>
</html>
